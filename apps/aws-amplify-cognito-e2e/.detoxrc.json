{
  "testRunner": {
    "args": {
      "$0": "jest",
      "config": "./jest.config.cts"
    },
    "jest": {
      "setupTimeout": 120000
    }
  },
  "apps": {
    "ios.debug": {
      "type": "ios.app",
      "build": "cd ../../apps/aws-amplify-cognito/ios && xcodebuild -workspace AwsAmplifyCognito.xcworkspace -scheme AwsAmplifyCognito -configuration Debug -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' -derivedDataPath ./build -quiet",
      "binaryPath": "../../apps/aws-amplify-cognito/ios/build/Build/Products/Debug-iphonesimulator/AwsAmplifyCognito.app"
    },
    "ios.release": {
      "type": "ios.app",
      "build": "cd ../../apps/aws-amplify-cognito/ios && xcodebuild -workspace AwsAmplifyCognito.xcworkspace -scheme AwsAmplifyCognito -configuration Release -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' -derivedDataPath ./build -quiet",
      "binaryPath": "../../apps/aws-amplify-cognito/ios/build/Build/Products/Release-iphonesimulator/AwsAmplifyCognito.app"
    },

    "android.debug": {
      "type": "android.apk",
      "build": "cd ../../apps/aws-amplify-cognito/android && ./gradlew assembleDebug assembleAndroidTest -DtestBuildType=debug",
      "binaryPath": "../../apps/aws-amplify-cognito/android/app/build/outputs/apk/debug/app-debug.apk",
      "testBinaryPath": "../../apps/aws-amplify-cognito/android/app/build/outputs/apk/androidTest/debug/app-debug-androidTest.apk",
      "reversePorts": [8081]
    },
    "android.release": {
      "type": "android.apk",
      "build": "cd ../../apps/aws-amplify-cognito/android && ./gradlew assembleRelease assembleAndroidTest -DtestBuildType=release",
      "binaryPath": "../../apps/aws-amplify-cognito/android/app/build/outputs/apk/release/app-release.apk",
      "testBinaryPath": "../../apps/aws-amplify-cognito/android/app/build/outputs/apk/androidTest/release/app-release-androidTest.apk"
    }
  },
  "devices": {
    "simulator": {
      "type": "ios.simulator",
      "device": {
        "type": "iPhone 16"
      }
    },
    "emulator": {
      "type": "android.emulator",
      "device": {
        "avdName": "Pixel_3a_API_34_extension_level_7_arm64-v8a"
      }
    }
  },
  "configurations": {
    "ios.sim.release": {
      "device": "simulator",
      "app": "ios.release"
    },
    "ios.sim.debug": {
      "device": "simulator",
      "app": "ios.debug"
    },

    "android.emu.release": {
      "device": "emulator",
      "app": "android.release"
    },
    "android.emu.debug": {
      "device": "emulator",
      "app": "android.debug"
    }
  }
}
